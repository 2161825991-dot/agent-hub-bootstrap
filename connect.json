{
  "purpose": "connect_remote_agent_to_agent_hub",
  "guide_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/AGENT_CONNECT.md",
  "mcp_guide_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/AGENTHUB_MCP_README.md",
  "raw_base": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main",
  "install": {
    "windows": {
      "install_script": "install-agent.ps1",
      "install_dir": "%USERPROFILE%\\.agent-hub",
      "start_script": "%USERPROFILE%\\.agent-hub\\start-openclaw-agent.ps1"
    },
    "unix": {
      "install_script": "install-agent.sh",
      "install_dir": "~/.agent-hub",
      "start_script": "~/.agent-hub/start-openclaw-agent.sh"
    }
  },
  "mcp": {
    "server_file": "agenthub_mcp_server.py",
    "transport": "stdio",
    "tools": [
      "agenthub_register",
      "agenthub_heartbeat",
      "agenthub_inbox",
      "agenthub_send_message",
      "agenthub_ack",
      "agenthub_claim_task",
      "agenthub_complete_task",
      "agenthub_get_chat",
      "agenthub_list_tasks",
      "agenthub_status"
    ]
  },
  "required_inputs": [
    "hub_url",
    "token",
    "agent_id",
    "agent_name",
    "role"
  ],
  "allowed_write_locations": {
    "windows": [
      "%USERPROFILE%\\.agent-hub\\"
    ],
    "unix": [
      "~/.agent-hub/"
    ]
  },
  "forbidden_actions": [
    "do not upload token to GitHub",
    "do not modify Agent Hub server",
    "do not delete user project files",
    "do not reset existing repositories"
  ],
  "verification": [
    "client reports Hub online",
    "client registers successfully",
    "Agent Hub app shows agent online",
    "Agent Hub ping test returns agent.pong"
  ]
}
