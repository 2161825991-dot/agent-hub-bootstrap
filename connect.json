{
  "purpose": "connect_remote_agent_to_agent_hub",
  "start_here_for_ai_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/START_HERE_FOR_AI.md",
  "operations_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/AGENT_OPERATIONS.md",
  "guide_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/AGENT_CONNECT.md",
  "mcp_guide_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/AGENTHUB_MCP_README.md",
  "mcp_quickstart_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/MCP_QUICKSTART.md",
  "windows_mcp_prompt_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/WINDOWS_MCP_AGENT_PROMPT.md",
  "mcp_config_template_url": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main/mcp-config.template.json",
  "raw_base": "https://raw.githubusercontent.com/2161825991-dot/agent-hub-bootstrap/main",
  "install": {
    "windows": {
      "install_script": "install-agent.ps1",
      "install_dir": "%USERPROFILE%\\.agent-hub",
      "start_script": "%USERPROFILE%\\.agent-hub\\start-openclaw-agent.ps1",
      "mcp_config": "%USERPROFILE%\\.agent-hub\\agenthub-mcp-config.json"
    },
    "unix": {
      "install_script": "install-agent.sh",
      "install_dir": "~/.agent-hub",
      "start_script": "~/.agent-hub/start-openclaw-agent.sh",
      "mcp_config": "~/.agent-hub/agenthub-mcp-config.json"
    }
  },
  "mcp": {
    "server_file": "agenthub_mcp_server.py",
    "transport": "stdio",
    "tools": [
      "agenthub_register",
      "agenthub_heartbeat",
      "agenthub_inbox",
      "agenthub_send_message",
      "agenthub_ack",
      "agenthub_claim_task",
      "agenthub_complete_task",
      "agenthub_get_chat",
      "agenthub_list_tasks",
      "agenthub_status",
      "agenthub_list_agents",
      "agenthub_ping_agent",
      "agenthub_create_task",
      "agenthub_update_task_settings",
      "agenthub_list_decisions",
      "agenthub_resolve_decision"
    ]
  },
  "required_inputs": [
    "hub_url",
    "token",
    "agent_id",
    "agent_name",
    "role"
  ],
  "allowed_write_locations": {
    "windows": [
      "%USERPROFILE%\\.agent-hub\\"
    ],
    "unix": [
      "~/.agent-hub/"
    ]
  },
  "forbidden_actions": [
    "do not upload token to GitHub",
    "do not modify Agent Hub server",
    "do not delete user project files",
    "do not reset existing repositories"
  ],
  "verification": [
    "client reports Hub online",
    "client registers successfully",
    "Agent Hub app shows agent online",
    "Agent Hub ping test returns agent.pong"
  ]
}
