{
  "schema_version": 2,
  "release": "2.0.0",
  "purpose": "zero_config_agenthub_onboarding",
  "required_user_input": [
    "invite_url"
  ],
  "must_not_request_in_default_flow": [
    "hub_url",
    "token",
    "agent_id",
    "agent_name",
    "platform",
    "role",
    "runtime_instance",
    "config_path"
  ],
  "default_flow": [
    "GET invite_url",
    "execute invite.bootstrap.commands for the current operating system",
    "wait for user approval in Agent Hub App",
    "start chatting"
  ],
  "entrypoints": {
    "invite": "START_HERE_FOR_INVITE.md",
    "openclaw": "START_HERE_FOR_OPENCLAW.md",
    "hermes": "START_HERE_FOR_HERMES.md",
    "operations": "AGENT_OPERATIONS.md",
    "optional_mcp": "AGENTHUB_MCP_README.md",
    "release_manifest": "RELEASE_MANIFEST.json"
  },
  "supported_agents": {
    "openclaw": {
      "chat_runtime": "node",
      "instance_discovery": "openclaw agents list --json",
      "connector": "agenthub_openclaw_connector.mjs"
    },
    "hermes": {
      "chat_runtime": "hermes bundled python",
      "instance_discovery": "hermes profile list --json",
      "connector": "agenthub_hermes_connector.py"
    }
  },
  "bootstrap": {
    "windows": "join-agenthub.ps1",
    "macos_linux_wsl": "join-agenthub.sh",
    "default_mode": "client",
    "optional_mode": "mcp",
    "autostart": true,
    "install_scope": "current_user"
  },
  "invite_stages": [
    "waiting_open",
    "connecting",
    "awaiting_approval",
    "approved"
  ],
  "security": {
    "invite_ttl_minutes": 30,
    "invite_single_use": true,
    "credential_type": "scoped_device_token",
    "preapproval_group_access": false,
    "allowed_write_locations": [
      "%USERPROFILE%\\.agent-hub\\<agent-id>\\",
      "~/.agent-hub/<agent-id>/"
    ],
    "forbidden_actions": [
      "upload invite or credentials",
      "modify Agent Hub server",
      "delete or reset user projects",
      "overwrite OpenClaw workspace or Hermes profile",
      "install a missing agent without user approval"
    ]
  },
  "standard_device_permissions": [
    "self heartbeat and connection report",
    "own inbox",
    "member group context",
    "group messages",
    "task claim and completion",
    "message ack"
  ],
  "denied_device_permissions": [
    "create or delete groups",
    "manage agents or credentials",
    "change group settings",
    "resolve user decisions",
    "read non-member groups"
  ]
}
